rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // --- COLLECTIONS ---

    // GLOBAL COMMENTS (Collection Group Query support)
    match /{path=**}/comments/{commentId} {
      allow read: if isVerifiedUser();
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      // Allow profile creation upon initial signup before verification is completed.
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isVerifiedUser();
    }

    // POSTS
    match /posts/{postId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser() && request.resource.data.userId == request.auth.uid;
      
      // Allow general updates for likes/reposts/commentsCount by verified users
      allow update: if isVerifiedUser();

      // Allow deletion by the post owner
      allow delete: if isVerifiedUser() && resource.data.userId == request.auth.uid;

      // COMMENTS (Subcollection)
      match /comments/{commentId} {
        allow read: if isVerifiedUser();
        allow create: if isVerifiedUser() && request.resource.data.userId == request.auth.uid;
        allow update: if isVerifiedUser() && resource.data.userId == request.auth.uid;
        
        // Deletion allowed for comment owner OR post owner
        allow delete: if isVerifiedUser() && (
          resource.data.userId == request.auth.uid || 
          get(/databases/$(database)/documents/posts/$(postId)).data.userId == request.auth.uid
        );
      }
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read, update, delete: if isVerifiedUser() && resource.data.toUserId == request.auth.uid;
      allow create: if isSignedIn(); // Allow system or other users to trigger notifications
    }

    // MESSAGES
    match /messages/{messageId} {
      allow read: if isVerifiedUser() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isVerifiedUser() && request.resource.data.senderId == request.auth.uid;
    }
  }
}
